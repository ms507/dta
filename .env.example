# Binance API Credentials
# Get your keys at https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Set to "true" for Binance Spot Testnet (https://testnet.binance.vision)
# Set to "false" for LIVE trading with real funds
BINANCE_TESTNET=true

# Comma-separated list of trading pairs
TRADING_SYMBOLS=BTCUSDT,ETHUSDT

# Candle interval: 1m, 3m, 5m, 15m, 30m, 1h, 2h, 4h, 1d
TIMEFRAME=15m

# Number of historical candles to fetch for indicator calculation
LOOKBACK_CANDLES=100

# Minimum number of strategies (out of 5) that must agree to open a trade
MIN_SIGNAL_CONSENSUS=3

# How often to re-evaluate signals (seconds)
CHECK_INTERVAL=60

# ── Risk Management ────────────────────────────────────────────
# Max percentage of USDT balance to allocate per trade (0.02 = 2%)
MAX_POSITION_PCT=0.02

# Stop-loss distance from entry price (0.015 = 1.5%)
STOP_LOSS_PCT=0.015

# Take-profit distance from entry price (0.03 = 3%)
TAKE_PROFIT_PCT=0.03

# Halt new trades for the day after losing this fraction of starting balance (0.05 = 5%)
MAX_DAILY_LOSS_PCT=0.05

# Maximum number of simultaneously open positions
MAX_OPEN_POSITIONS=3
